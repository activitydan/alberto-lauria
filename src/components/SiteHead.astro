---
const base = import.meta.env.BASE_URL

const menu = [
  {
    id: 'about',
    text: 'About',
    href: '/about',
  },
  {
    id: 'work',
    text: 'Work',
  },
  {
    id: 'contact',
    text: 'Contact',
  },
]
---

<header class="site-head" data-intersect>
  <div class="site-head__container">
    <div class="sb-logo">
      <a href={base}>
        <svg
          class="js-logo"
          width="280"
          height="280"
          viewBox="0 0 1024 1024"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
